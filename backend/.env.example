TINK_CLIENT_ID=your_tink_client_id
TINK_CLIENT_SECRET=your_tink_client_secret
TINK_API_URL=https://api.tink.com
TINK_LINK_URL=https://link.tink.com

# Local dev
MERCHANT_APP_URL=http://localhost:3001
PPB_APP_URL=http://localhost:3000
PORT=3002
NODE_ENV=development

JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=1h

